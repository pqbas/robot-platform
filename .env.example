# App mode: "robot" (Jetson, campo) or "server" (PC del lab, internet)
ROBOT_MODE=robot

# Server port
PORT=8080

# Database URL
# Robot:  sqlite+aiosqlite:///data/robot/robot.db
# Server: postgresql+asyncpg://platform:dev-password@localhost:5432/robot_platform
DATABASE_URL=sqlite+aiosqlite:///data/robot/robot.db

# Storage directories
MODELS_DIR=data/robot/models
FRAMES_DIR=data/server/frames

# Robot ID (auto-detected from Jetson serial, only needed for dev/testing)
# ROBOT_ID=dev-local

# Sync (robot mode only)
# SYNC_SERVER_URL=http://localhost:9090
# SYNC_API_KEY=your-api-key-here
# SYNC_INTERVAL=300

# Auth (server mode only)
# AUTH_SECRET_KEY=change-me-to-a-random-secret
