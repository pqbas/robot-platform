# App mode: "robot" (Jetson, campo) or "server" (PC del lab, internet)
ROBOT_MODE=robot

# Database URL
# Robot: sqlite+aiosqlite:///counting.db
# Server: postgresql+asyncpg://user:password@localhost:5432/counting
DATABASE_URL=sqlite+aiosqlite:///counting.db

# Robot ID (auto-detected from Jetson serial, only needed for dev/testing)
# ROBOT_ID=dev-local

# Sync (robot mode only)
# SYNC_SERVER_URL=https://labinm-server.cfargotunnel.com
# SYNC_API_KEY=your-api-key-here
# SYNC_INTERVAL=300

# Auth (server mode only)
# AUTH_SECRET_KEY=change-me-to-a-random-secret
